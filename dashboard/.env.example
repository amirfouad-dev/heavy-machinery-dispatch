# Base URL of the FastAPI backend
VITE_API_BASE_URL=http://your-server-ip:8000

# Must match API_KEY in the backend's .env when auth is enabled.
# Note: this value ships in the built frontend, so it is a shared secret for
# an internal tool, not a per-user credential. Leave blank if API_KEY is unset.
VITE_API_KEY=
