# Telegram Bot Configuration
# Heavy Machinery Target Configuration
# Required: A Rotating Proxy Service URL to bypass Cloudflare/CloudFront on machinery sites
PROXY_URL=http://user:pass@proxy.example.com:8000
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_IDS=your_chat_id_1,your_chat_id_2

# Email Configuration (for Daily Digest)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
TO_EMAIL=destination_email@example.com

# Server URL used by local_harvester.py to push listings to the remote API
SERVER_URL=http://your-server-ip:8000

# API security
# If API_KEY is set, all mutating endpoints (claim/remove/complete/users/push)
# require an "X-API-Key" header matching this value. Leave blank to disable auth.
# The dashboard must send the same value via VITE_API_KEY, and the local harvester
# sends it automatically.
API_KEY=change_me_to_a_long_random_string

# Comma-separated list of allowed CORS origins (the dashboard's URL) in production,
# e.g. https://dispatch.yourcompany.com . Leave as * only for local development.
ALLOWED_ORIGINS=*

# Chat ID that receives operational alerts (e.g. "scraper returned 0 results").
# Defaults to the first registered operator if unset.
ADMIN_CHAT_ID=your_admin_chat_id

# eBay Browse API (free). Create a developer account at https://developer.ebay.com,
# then under "Application Keys" create a PRODUCTION keyset and copy the
# App ID (client id) and Cert ID (client secret) here. The eBay source is
# automatically skipped while these are blank.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
